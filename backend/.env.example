# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# LLM Configuration
# Supported providers: anthropic, openai, local
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-api-key-here
# OPENAI_API_KEY=your-openai-key-here

# Model Configuration
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3

# Application
APP_NAME=Klassa KRT Classification System
APP_VERSION=1.0.0
MODEL_VERSION=krt-1.0.0

# Security
ENABLE_CORS=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
